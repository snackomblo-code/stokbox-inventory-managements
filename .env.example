# MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/inventaris?retryWrites=true&w=majority
MONGO_DB_NAME=inventaris

# Cloudinary
# Prioritas: CLOUDINARY_URL (format: cloudinary://KEY:SECRET@CLOUD_NAME).
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_FOLDER=inventaris

# Application
APP_SECRET_KEY=please-change-this-to-a-random-secret
APP_ENV=development
DEBUG=true
